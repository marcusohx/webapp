<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link rel="icon" type="image/png" sizes="16x16" href="../plugins/images/favicon.png">
  <title>login page</title>
  <link rel="stylesheet" type="text/css" href="/css/style.css" />
</head>
<body>
  <div id="wrapper">
        <div id="left">
          <div id="signin">
            <div class="logo">
              
              <a href="/" ><img src="../plugins/images/Webp.net-resizeimage (6).png" alt="Sluralpright" /></a>
            </div>

              
              
          <footer id="main-footer">
            <div>
              <form method="POST" action="/forgetpassword/<%= hash %>">
                <label style="font-size: 1rem; ">Email</label>
                <div>
                <label>Password</label>
                <input type="password" class="text-input" name="password" required minlength="8" maxlength="16"/>
              </div>
              <div>
                <label>Re-enter Password</label>
                <input type="password" class="text-input" name="passwordMatch" required minlength="8" maxlength="16"/>
              </div>

                <button type="submit" class="primary-btn">change password</button>
              </form>
              <div class="erros">
              <% if(errors != undefined){ %>
                <ul>
                  <% errors.forEach(function(error){ %>
                    <b><li style="text-align: center;"><%= error.msg %> </li></b>

                  <% }) %>
                  </ul>
                <% } %>
              </div>
              </div>
              <div>
                <a href="/login" style="font-size: 1rem; color: #191970;" class="btn btn-info btn-rounded waves-effect waves-light m-b-40">Login Here</a> 
              </div>
              <div>
            <p>Copyright &copy; 2019, Company All Rights Reserved</p>
            <div>
              <a href="#">terms of use</a> | <a href="#">Privacy Policy</a>
            </div>
          </footer>
        </div>
         
         </div>
  </body>

</html>